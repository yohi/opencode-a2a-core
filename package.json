{
  "name": "opencode-a2a-core",
  "version": "1.0.0",
  "description": "OpenCode拡張のためのA2A共通基盤 & プラグインフレームワーク",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "a2a",
    "agent",
    "typescript",
    "node22"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0"
  }
}